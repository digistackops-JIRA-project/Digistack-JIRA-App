// ============================================================================
// Frontend Team Pipeline — Jenkinsfile
// Vue 3 — test → build → deploy Dev → Staging → Prod
// ============================================================================
pipeline {
    agent any

    environment {
        IMAGE_NAME = 'sapsecops/admin-frontend'
        IMAGE_TAG  = "${BUILD_NUMBER}-${GIT_COMMIT[0..6]}"
        REGISTRY   = 'registry.sapsecops.in'
    }

    stages {
        stage('Checkout') { steps { checkout scm } }

        // ── Install Dependencies ──────────────────────────────────────────────
        stage('Install') {
            agent { docker { image 'node:20-alpine'; args '-u root' } }
            steps {
                dir('frontend') { sh 'npm ci' }
            }
        }

        // ── Unit Tests ────────────────────────────────────────────────────────
        stage('Unit Tests') {
            agent { docker { image 'node:20-alpine'; args '-u root' } }
            steps {
                dir('frontend') {
                    sh 'npm run test:unit -- --reporter=junit --outputFile=test-results.xml'
                }
            }
            post {
                always { junit 'frontend/test-results.xml' }
            }
        }

        // ── Lint ──────────────────────────────────────────────────────────────
        stage('Lint') {
            agent { docker { image 'node:20-alpine'; args '-u root' } }
            steps {
                dir('frontend') { sh 'npm run lint -- --no-fix' }
            }
        }

        // ── Build ─────────────────────────────────────────────────────────────
        stage('Build') {
            agent { docker { image 'node:20-alpine'; args '-u root' } }
            steps {
                dir('frontend') {
                    withEnv(["VITE_API_BASE_URL=https://api.admin.sapsecops.in"]) {
                        sh 'npm run build'
                    }
                }
            }
        }

        // ── Docker Build & Push ────────────────────────────────────────────────
        stage('Docker Build & Push') {
            steps {
                dir('frontend') {
                    sh "docker build -t ${REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG} ."
                    withCredentials([usernamePassword(credentialsId: 'docker-registry', usernameVariable: 'REG_USER', passwordVariable: 'REG_PASS')]) {
                        sh "echo \$REG_PASS | docker login ${REGISTRY} -u \$REG_USER --password-stdin"
                        sh "docker push ${REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}"
                    }
                }
            }
        }

        // ── Deploy Dev ────────────────────────────────────────────────────────
        stage('Deploy → Dev') {
            steps {
                sshagent(['ssh-dev-server']) {
                    sh """
                        ssh deploy@${DEV_HOST} '
                            docker pull ${REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}
                            docker stop admin-frontend || true
                            docker rm   admin-frontend || true
                            docker run -d --name admin-frontend \
                                --restart always \
                                -p 80:80 \
                                ${REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}
                        '
                    """
                }
            }
        }

        stage('Smoke Test — Dev') {
            steps {
                sh '''
                    sleep 5
                    STATUS=$(curl -s -o /dev/null -w "%{http_code}" http://${DEV_HOST})
                    [ "$STATUS" = "200" ] || (echo "Frontend smoke test FAILED: $STATUS" && exit 1)
                    echo "Frontend Dev smoke test passed ✅"
                '''
            }
        }

        stage('Approval → Staging') {
            steps { input message: "Deploy Frontend ${IMAGE_TAG} to STAGING?", ok: "Deploy" }
        }

        stage('Deploy → Staging') {
            steps {
                sshagent(['ssh-staging-server']) {
                    sh """
                        ssh deploy@${STAGING_HOST} '
                            docker pull ${REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}
                            docker stop admin-frontend || true
                            docker rm   admin-frontend || true
                            docker run -d --name admin-frontend \
                                --restart always -p 80:80 \
                                ${REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}
                        '
                    """
                }
            }
        }

        stage('Approval → Prod') {
            steps { input message: "⚠️  Deploy Frontend to PRODUCTION?", ok: "Yes, go live" }
        }

        stage('Deploy → Prod') {
            steps {
                sshagent(['ssh-prod-server']) {
                    sh """
                        ssh deploy@${PROD_HOST} '
                            docker pull ${REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}
                            docker stop admin-frontend || true
                            docker rm   admin-frontend || true
                            docker run -d --name admin-frontend \
                                --restart always -p 80:80 \
                                ${REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}
                        '
                    """
                }
            }
        }
    }

    post {
        success { echo "✅ Frontend deployed — ${IMAGE_TAG}" }
        failure { echo "❌ Frontend pipeline FAILED" }
        always  { sh 'docker logout ${REGISTRY} || true' }
    }
}
