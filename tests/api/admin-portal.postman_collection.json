{
  "info": {
    "name": "SapSecOps Admin Portal — API Tests",
    "description": "Full API test collection for Phase 1 Admin Portal. Import into Postman or run with Newman.\n\nUsage:\n  newman run tests/api/admin-portal.postman_collection.json \\\n    --env-var baseUrl=http://staging-host:8000",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",   "value": "http://localhost:8000" },
    { "key": "authToken", "value": "" },
    { "key": "teamId",    "value": "" },
    { "key": "managerId", "value": "" },
    { "key": "employeeId","value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": { "method": "GET", "url": "{{baseUrl}}/health" },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('status is UP', () => pm.expect(pm.response.json().status).to.eql('UP'));",
            "pm.test('version exists', () => pm.expect(pm.response.json().version).to.exist);"
          ]}}]
        },
        {
          "name": "GET /health/live",
          "request": { "method": "GET", "url": "{{baseUrl}}/health/live" },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('status ALIVE', () => pm.expect(pm.response.json().status).to.eql('ALIVE'));"
          ]}}]
        },
        {
          "name": "GET /health/ready",
          "request": { "method": "GET", "url": "{{baseUrl}}/health/ready" },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('status READY', () => pm.expect(pm.response.json().status).to.eql('READY'));",
            "pm.test('database UP', () => pm.expect(pm.response.json().database).to.eql('UP'));"
          ]}}]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth/login — success",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"email\":\"admin@sapsecops.in\",\"password\":\"Admin123\"}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('has access_token', () => pm.expect(pm.response.json().access_token).to.exist);",
            "pm.test('token_type is bearer', () => pm.expect(pm.response.json().token_type).to.eql('bearer'));",
            "pm.collectionVariables.set('authToken', pm.response.json().access_token);"
          ]}}]
        },
        {
          "name": "POST /auth/login — wrong password",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"email\":\"admin@sapsecops.in\",\"password\":\"WrongPass\"}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 401', () => pm.response.to.have.status(401));"
          ]}}]
        },
        {
          "name": "GET /teams — no auth (expect 401)",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/teams/" },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 401', () => pm.response.to.have.status(401));"
          ]}}]
        }
      ]
    },
    {
      "name": "Teams",
      "item": [
        {
          "name": "GET /teams — list (empty)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/teams/",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }]
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Response is array', () => pm.expect(pm.response.json()).to.be.an('array'));"
          ]}}]
        },
        {
          "name": "POST /teams — create",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/teams/",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\"team_name\":\"DevOps\"}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "pm.test('team_name is DevOps', () => pm.expect(pm.response.json().team_name).to.eql('DevOps'));",
            "pm.collectionVariables.set('teamId', pm.response.json().id);"
          ]}}]
        },
        {
          "name": "POST /teams — duplicate (expect 409)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/teams/",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\"team_name\":\"DevOps\"}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 409', () => pm.response.to.have.status(409));"
          ]}}]
        }
      ]
    },
    {
      "name": "Managers",
      "item": [
        {
          "name": "POST /managers — create",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/managers/",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\"name\":\"John Manager\",\"email\":\"john@sapsecops.in\",\"password\":\"Manager1\",\"phone\":\"+91-9000000000\",\"team_id\":{{teamId}}}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "pm.test('name matches', () => pm.expect(pm.response.json().name).to.eql('John Manager'));",
            "pm.test('no password in response', () => pm.expect(pm.response.json().hashed_password).to.be.undefined);",
            "pm.collectionVariables.set('managerId', pm.response.json().id);"
          ]}}]
        },
        {
          "name": "GET /managers — list",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/managers/",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }]
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('At least 1 manager', () => pm.expect(pm.response.json().length).to.be.gte(1));"
          ]}}]
        }
      ]
    },
    {
      "name": "Employees",
      "item": [
        {
          "name": "POST /employees — create",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/employees/",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\"name\":\"Alice Employee\",\"email\":\"alice@sapsecops.in\",\"password\":\"Employee1\",\"phone\":\"+91-8000000000\",\"team_id\":{{teamId}},\"manager_id\":{{managerId}}}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "pm.test('manager_name present', () => pm.expect(pm.response.json().manager_name).to.exist);",
            "pm.collectionVariables.set('employeeId', pm.response.json().id);"
          ]}}]
        },
        {
          "name": "GET /employees/by-manager",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/employees/by-manager",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }]
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('grouped by manager', () => { const g = pm.response.json(); pm.expect(g[0].manager_name).to.exist; pm.expect(g[0].employees).to.be.an('array'); });"
          ]}}]
        },
        {
          "name": "DELETE /employees/{id}",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/employees/{{employeeId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }]
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 204', () => pm.response.to.have.status(204));"
          ]}}]
        }
      ]
    }
  ]
}
